# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Spotify search fallback (client credentials — optional if using Supabase edge function)
# Spotify OAuth login is configured in Supabase Dashboard → Auth → Spotify provider
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your-spotify-client-id
EXPO_PUBLIC_SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
